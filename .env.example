# Required env vars for hyperfaceless-render-node.
# Copy to .env locally; Railway exposes these via its env-var UI in production.

# Port the Express server listens on. Railway sets this automatically.
PORT=3000

# Where rendered MP4s are written. The Dockerfile defaults this to /data/renders.
HYPERFRAMES_WORK_DIR=/data/renders

# Hard cap (ms) for a single render. Default 300000 (5 min).
RENDER_TIMEOUT_MS=300000

# RAILWAY_PUBLIC_DOMAIN is auto-set by Railway. No need to fill manually.
# Only set this when running locally if you want absolute output_url responses.
# RAILWAY_PUBLIC_DOMAIN=
